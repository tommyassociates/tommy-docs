{
  "mcpSpec": "0.2.0",
  "mcpVersion": "2025-11-25",
  "description": "Workforce, scheduling, documents, and chat for service teams.",
  "server": {
    "name": "tommy",
    "version": "1.0.0",
    "title": "Tommy",
    "description": "Workforce, scheduling, documents, and chat for service teams."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    },
    "resources": {
      "subscribe": false,
      "listChanged": false
    },
    "prompts": {
      "listChanged": false
    }
  },
  "transport": {
    "type": "streamable-http",
    "url": "https://api.mytommy.com/mcp"
  },
  "tools": [
    {
      "name": "tommy_get_status",
      "description": "Get current account/team readiness, recent activity counts, and recommended next actions.",
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "annotations": {
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false,
        "readOnlyHint": true
      }
    },
    {
      "name": "tommy_query",
      "description": "Read-only paginated lookup across approved Tommy entity types: shifts, availabilities, documents, clients, contacts, team_members. Pagination via page/per.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "entity": {
            "type": "string",
            "enum": [
              "shifts",
              "availabilities",
              "documents",
              "clients",
              "contacts",
              "team_members"
            ],
            "description": "The entity type to list."
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "per": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 25
          },
          "id": {
            "type": [
              "integer",
              "string"
            ],
            "description": "Optional single-record lookup by id."
          }
        },
        "required": [
          "entity"
        ]
      },
      "annotations": {
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false,
        "readOnlyHint": true
      }
    },
    {
      "name": "tommy_search_people",
      "description": "Search across team_members, clients, or contacts by name/email. Pass kind to narrow; q is the case-insensitive search term.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string",
            "description": "Search text (matches name, email, phone)."
          },
          "kind": {
            "type": "string",
            "enum": [
              "team_members",
              "clients",
              "contacts"
            ],
            "description": "Optional. Defaults to all kinds."
          },
          "per": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 25
          }
        },
        "required": [
          "q"
        ]
      },
      "annotations": {
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false,
        "readOnlyHint": true
      }
    },
    {
      "name": "tommy_get_insights",
      "description": "Read-only summaries and metrics for the active team. Pass metric to narrow: overview, attendance, shifts, documents.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "metric": {
            "type": "string",
            "enum": [
              "overview",
              "attendance",
              "shifts",
              "documents"
            ],
            "default": "overview"
          },
          "window": {
            "type": "string",
            "enum": [
              "24h",
              "7d",
              "30d",
              "90d"
            ],
            "default": "7d",
            "description": "Lookback window for time-series metrics."
          }
        }
      },
      "annotations": {
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false,
        "readOnlyHint": true
      }
    },
    {
      "name": "tommy_manage_shift",
      "description": "Create, update, cancel, drop, or swap a workforce shift. Pass dry_run: true to preview. Cancel/drop/swap require attributes.confirm: true.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "operation": {
            "type": "string",
            "enum": [
              "create",
              "update",
              "cancel",
              "drop",
              "swap"
            ],
            "description": "What to do."
          },
          "shift_id": {
            "type": [
              "integer",
              "string"
            ],
            "description": "For update/cancel/drop/swap."
          },
          "dry_run": {
            "type": "boolean",
            "default": false,
            "description": "Preview without applying."
          },
          "idempotency_key": {
            "type": "string",
            "description": "Dedupe retries."
          },
          "attributes": {
            "type": "object",
            "description": "Shift fields to set or update.",
            "properties": {
              "start_at": {
                "type": "string",
                "format": "date-time",
                "description": "When the shift starts."
              },
              "end_at": {
                "type": "string",
                "format": "date-time",
                "description": "When the shift ends."
              },
              "assignee_id": {
                "type": [
                  "integer",
                  "string"
                ],
                "description": "Team member to work the shift.",
                "x-bot-form": {
                  "field": "team_member"
                }
              },
              "role_name": {
                "type": "string",
                "description": "Optional role label for the shift."
              },
              "replacement_team_member_id": {
                "type": [
                  "integer",
                  "string"
                ],
                "description": "For swap: the team member to swap to.",
                "x-bot-form": {
                  "field": "team_member",
                  "label": "Replacement team member"
                }
              },
              "confirm": {
                "type": "boolean",
                "default": false,
                "description": "Required for cancel, drop, or swap.",
                "x-bot-form": {
                  "label": "I confirm this action"
                }
              }
            }
          }
        },
        "required": [
          "operation"
        ]
      },
      "annotations": {
        "destructiveHint": true,
        "idempotentHint": false,
        "openWorldHint": false,
        "readOnlyHint": false
      }
    },
    {
      "name": "tommy_manage_shift_requirements",
      "description": "Create, update, cancel, approve, or reject a shift request (request / drop / swap / offer). approve_request, reject_request, and cancel_request require attributes.confirm: true.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "operation": {
            "type": "string",
            "enum": [
              "create_request",
              "update_request",
              "cancel_request",
              "approve_request",
              "reject_request"
            ],
            "description": "What to do."
          },
          "request_id": {
            "type": [
              "integer",
              "string"
            ],
            "description": "For update/cancel/approve/reject."
          },
          "shift_id": {
            "type": [
              "integer",
              "string"
            ],
            "description": "For create_request."
          },
          "kind": {
            "type": "string",
            "enum": [
              "request",
              "drop",
              "swap",
              "offer"
            ],
            "description": "For create_request: what kind of request."
          },
          "dry_run": {
            "type": "boolean",
            "default": false
          },
          "idempotency_key": {
            "type": "string"
          },
          "attributes": {
            "type": "object",
            "description": "Optional fields for create/update.",
            "properties": {
              "swap_shift_id": {
                "type": [
                  "integer",
                  "string"
                ],
                "description": "For swap requests, the shift to swap into.",
                "x-bot-form": {
                  "field": "shift"
                }
              },
              "message": {
                "type": "string",
                "description": "Optional note.",
                "x-bot-form": {
                  "field": "textarea"
                }
              },
              "confirm": {
                "type": "boolean",
                "default": false,
                "description": "Required before cancelling, approving, or rejecting.",
                "x-bot-form": {
                  "label": "I confirm this action"
                }
              }
            }
          }
        },
        "required": [
          "operation"
        ]
      },
      "annotations": {
        "destructiveHint": true,
        "idempotentHint": false,
        "openWorldHint": false,
        "readOnlyHint": false
      }
    },
    {
      "name": "tommy_manage_availability",
      "description": "Update an availability record or record a clock-in/out attendance.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "operation": {
            "type": "string",
            "enum": [
              "update",
              "clock_in",
              "clock_out"
            ],
            "description": "What to do."
          },
          "availability_id": {
            "type": [
              "integer",
              "string"
            ],
            "description": "For update."
          },
          "attendance_id": {
            "type": [
              "integer",
              "string"
            ],
            "description": "For clock_out."
          },
          "team_member_id": {
            "type": [
              "integer",
              "string"
            ],
            "description": "For clock_in/clock_out: who is clocking in or out."
          },
          "dry_run": {
            "type": "boolean",
            "default": false
          },
          "idempotency_key": {
            "type": "string"
          },
          "attributes": {
            "type": "object",
            "description": "Availability or attendance fields.",
            "properties": {
              "start_at": {
                "type": "string",
                "format": "date-time",
                "description": "Start of the availability window."
              },
              "end_at": {
                "type": "string",
                "format": "date-time",
                "description": "End of the availability window."
              },
              "status": {
                "type": "string",
                "enum": [
                  "unavailable",
                  "neutral",
                  "available",
                  "preferred"
                ],
                "description": "Availability status for the requested time range."
              },
              "date": {
                "type": "string",
                "format": "date",
                "description": "Availability date.",
                "x-bot-form": {
                  "hidden": true
                }
              },
              "periods": {
                "type": "array",
                "description": "Which availability windows to update.",
                "items": {
                  "type": "string",
                  "enum": [
                    "am",
                    "pm",
                    "nd"
                  ]
                },
                "x-bot-form": {
                  "hidden": true
                }
              },
              "availability": {
                "type": "string",
                "enum": [
                  "unavailable",
                  "neutral",
                  "available",
                  "preferred"
                ],
                "description": "Availability value to apply to the selected periods.",
                "x-bot-form": {
                  "hidden": true
                }
              }
            }
          }
        },
        "required": [
          "operation"
        ]
      },
      "annotations": {
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": false,
        "readOnlyHint": false
      }
    },
    {
      "name": "tommy_manage_documents",
      "description": "Create, update, cancel, approve, or reject a leave request. Approve/reject/cancel require attributes.confirm: true.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "operation": {
            "type": "string",
            "enum": [
              "create_leave",
              "update_leave",
              "cancel_leave",
              "approve_leave",
              "reject_leave"
            ],
            "description": "What to do."
          },
          "leave_id": {
            "type": [
              "integer",
              "string"
            ],
            "description": "For update/cancel/approve/reject."
          },
          "dry_run": {
            "type": "boolean",
            "default": false,
            "description": "Preview without applying."
          },
          "idempotency_key": {
            "type": "string"
          },
          "attributes": {
            "type": "object",
            "description": "Leave request fields.",
            "properties": {
              "start_at": {
                "type": "string",
                "format": "date-time",
                "description": "When the leave starts."
              },
              "end_at": {
                "type": "string",
                "format": "date-time",
                "description": "When the leave ends."
              },
              "leave_kind": {
                "type": "string",
                "enum": [
                  "annual",
                  "sick",
                  "personal",
                  "long_service",
                  "unpaid",
                  "other"
                ],
                "description": "Type of leave."
              },
              "message": {
                "type": "string",
                "description": "Optional note.",
                "x-bot-form": {
                  "field": "textarea"
                }
              },
              "confirm": {
                "type": "boolean",
                "default": false,
                "description": "Required before approving, rejecting, or cancelling.",
                "x-bot-form": {
                  "label": "I confirm this action"
                }
              }
            }
          }
        },
        "required": [
          "operation"
        ]
      },
      "annotations": {
        "destructiveHint": true,
        "idempotentHint": false,
        "openWorldHint": false,
        "readOnlyHint": false
      }
    },
    {
      "name": "tommy_set_memory",
      "description": "Update the operator's persistent AI memory document for this team. Call with merge: true to merge keys, or replace: true to overwrite. The document is read back via tommy://memory.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "document": {
            "type": "object",
            "description": "Free-form JSON object (goals, audience, tone, anything the agent should remember)."
          },
          "merge": {
            "type": "boolean",
            "default": true,
            "description": "Merge document into existing memory (default)."
          },
          "replace": {
            "type": "boolean",
            "default": false,
            "description": "Replace memory entirely instead of merging."
          }
        },
        "required": [
          "document"
        ]
      },
      "annotations": {
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": false,
        "readOnlyHint": false
      }
    },
    {
      "name": "tommy_request_support",
      "description": "Record a support request from the team. The request is logged and instrumented; a real ticket is created downstream by the support pipeline. Use this instead of exposing arbitrary contact channels.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "idempotency_key": {
            "type": "string"
          },
          "attributes": {
            "type": "object",
            "description": "Support ticket fields.",
            "properties": {
              "summary": {
                "type": "string",
                "description": "One-line summary."
              },
              "details": {
                "type": "string",
                "description": "Free-form detail.",
                "x-bot-form": {
                  "field": "textarea"
                }
              },
              "category": {
                "type": "string",
                "enum": [
                  "bug",
                  "billing",
                  "data",
                  "integrations",
                  "onboarding",
                  "other"
                ],
                "description": "What kind of issue?"
              },
              "urgency": {
                "type": "string",
                "enum": [
                  "low",
                  "normal",
                  "high",
                  "urgent"
                ],
                "description": "How urgent?"
              }
            }
          }
        }
      },
      "annotations": {
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": false,
        "readOnlyHint": false
      }
    }
  ],
  "resources": [
    {
      "uri": "tommy://guide",
      "name": "guide",
      "description": "Read first. Tommy vocabulary, recommended workflow, and tool conventions."
    },
    {
      "uri": "tommy://team/current",
      "name": "team-current",
      "description": "Live snapshot of the active team: name, owner, counts (members, clients, shifts, availabilities, documents), and installed addons."
    },
    {
      "uri": "tommy://features",
      "name": "features",
      "description": "Feature flags and addon slugs enabled for the active team."
    },
    {
      "uri": "tommy://memory",
      "name": "memory",
      "description": "Operator memory document for this team. Free-form JSON the agent has saved (goals, audience, tone, anything worth remembering). Managed via tommy_set_memory."
    },
    {
      "uri": "tommy://prompts/{name}",
      "name": "prompt",
      "description": "Rendered prompt template by name. Available names listed in the prompt registry."
    }
  ],
  "prompts": [
    {
      "name": "documents",
      "description": "Workflow guidance for requesting, approving, and reminding on team documents.",
      "arguments": []
    },
    {
      "name": "shift-management",
      "description": "Workflow guidance for creating, updating, or cancelling shifts.",
      "arguments": [
        {
          "name": "shift_id",
          "description": "Optional shift identifier when working with an existing shift.",
          "required": false
        }
      ]
    },
    {
      "name": "workforce-assistant",
      "description": "System prompt for the in-app workforce assistant. Covers tone, scope, and tool-use guidance.",
      "arguments": []
    }
  ]
}
